# Pyth Hermes endpoint (optional)
# Default in code: https://hermes.pyth.network
HERMES_ENDPOINT=https://hermes.pyth.network

# Required: BTC/USD feed id from Pyth price feed registry
BTC_USD_PRICE_FEED_ID=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43

# Optional: Ethereum RPC URL (required for `examples/alloy_integration.rs`)
ETH_RPC_URL=https://eth.llamarpc.com

# Optional: Ethereum WebSocket RPC URL (used by fastwebsockets path in src/main.rs)
ETH_RPC_WS_URL=wss://eth.llamarpc.com

# Optional: API key used when ETH_RPC_URL / ETH_RPC_WS_URL contain
# {$API_KEY} or ${API_KEY} placeholders.
# ETH_RPC_API_KEY=your-provider-api-key

# Optional: Output timezone for log formatting.
# Supported values:
# - UTC
# - EST, CST, MST, PST
# - UTC+HH:MM (example: UTC+02:00)
# - UTC-HH:MM (example: UTC-07:00)
OUTPUT_TIMEZONE=EST
